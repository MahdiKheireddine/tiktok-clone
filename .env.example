# --- Core ---
ENVIRONMENT=development         # development | production
SECRET_KEY=                     # any long random string; generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# --- Database (PostgreSQL) ---
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Redis (only required when ENVIRONMENT=production) ---
# Used by Django Channels for the WebSocket layer.
REDIS_URL=redis://localhost:6379/0

# --- Email via Brevo SMTP (only required when ENVIRONMENT=production) ---
# Get credentials at: https://app.brevo.com/settings/keys/smtp
# DEFAULT_FROM_EMAIL must be a verified sender in your Brevo account.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=              # e.g. abc123def@smtp-brevo.com
EMAIL_HOST_PASSWORD=          # SMTP key from Brevo dashboard
DEFAULT_FROM_EMAIL=           # e.g. "TikTok Clone <no-reply@yourdomain.com>"

# --- Cloudinary for media storage (only required when ENVIRONMENT=production) ---
# Grab the full URL from your Cloudinary dashboard → Settings → API Keys.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
