# --- Core ---
ENVIRONMENT=development         # development | production
SECRET_KEY=                     # any long random string; generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# --- Database (PostgreSQL) ---
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Redis (only required when ENVIRONMENT=production) ---
# Used by Django Channels for the WebSocket layer.
REDIS_URL=redis://localhost:6379/0

# --- Email (only required when ENVIRONMENT=production) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- AWS S3 for media storage (only required when ENVIRONMENT=production) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
